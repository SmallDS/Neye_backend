# PostgreSQL connection used by the API container.
DATABASE_URL=postgresql://neye:change-me@postgres:5432/neye?schema=public

# Required in production. Use a long random string.
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=12h
# Used to encrypt AppSecret and other sensitive database settings.
SETTINGS_ENCRYPTION_KEY=replace-with-an-independent-long-random-secret

# Comma-separated browser origins allowed to call the API.
CORS_ORIGINS=https://web.example.com

# Initial admin account used only when RUN_DB_SEED=true.
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=change-me-before-deploy
SEED_ADMIN_DISPLAY_NAME=Admin

# Current databases were created with db push. Keep migrations disabled until
# the existing database has been baselined into Prisma Migrate.
PORT=3000
RUN_DB_MIGRATIONS=false
RUN_DB_PUSH=true
RUN_DB_SEED=false
RUN_CUSTOMER_PINYIN_BACKFILL=true
RUN_USER_TENANT_BACKFILL=true

# Wechat mini program authentication. Never expose APP_SECRET to the frontend.
WECHAT_MINIAPP_APP_ID=wx_your_app_id
WECHAT_MINIAPP_APP_SECRET=replace-with-wechat-app-secret
# release, trial, or develop. It controls which mini program version the QR code opens.
WECHAT_MINIAPP_ENV_VERSION=release