DATABASE_URL="postgresql://neye:neye_dev_password@localhost:5432/neye?schema=public"
JWT_SECRET="replace-with-a-long-random-dev-secret"
JWT_EXPIRES_IN="12h"
# Used to encrypt AppSecret and other sensitive database settings.
SETTINGS_ENCRYPTION_KEY=replace-with-an-independent-long-random-secret
CORS_ORIGINS="http://127.0.0.1:5666,http://localhost:5666"
SEED_ADMIN_USERNAME="admin"
SEED_ADMIN_PASSWORD="Admin123456"
SEED_ADMIN_DISPLAY_NAME="System Admin"
PORT="3100"
# Wechat mini program authentication (keep the secret on the API server only)
WECHAT_MINIAPP_APP_ID="wx_your_app_id"
WECHAT_MINIAPP_APP_SECRET="replace-with-wechat-app-secret"
WECHAT_MINIAPP_ENV_VERSION="release"
