# API 容器使用的 PostgreSQL 连接地址
DATABASE_URL=postgresql://neye:change-me@postgres:5432/neye?schema=public

# JWT 签名密钥，生产环境必须替换为强随机字符串
JWT_SECRET=change-me-to-a-long-random-secret
# 登录令牌有效期
JWT_EXPIRES_IN=12h

# 允许访问 API 的 Web 来源，多个地址使用逗号分隔
CORS_ORIGINS=https://web.example.com

# 初始化管理员账号，仅在 RUN_DB_SEED=true 时使用
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=change-me-before-deploy
SEED_ADMIN_DISPLAY_NAME=Admin

# API 容器内部监听端口
PORT=3000

# 当前数据库由 db push 管理，完成 Prisma baseline 前保持以下配置
RUN_DB_MIGRATIONS=false
RUN_DB_PUSH=true
# 仅在已审查 Prisma 警告并确认本次结构变更时临时开启，升级成功后改回 false
RUN_DB_PUSH_ACCEPT_DATA_LOSS=false

# 是否执行初始化管理员种子，已有生产数据时保持 false
RUN_DB_SEED=false

# 是否自动回填历史账号租户关系
RUN_USER_TENANT_BACKFILL=true
# 是否自动回填客户姓名拼音查询字段
RUN_CUSTOMER_PINYIN_BACKFILL=true
