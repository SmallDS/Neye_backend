# PostgreSQL connection used by the API container.
# If PostgreSQL runs in docker compose with service name "postgres", use this form:
DATABASE_URL="postgresql://neye:change-me@postgres:5432/neye?schema=public"

# Required in production. Use a long random string.
JWT_SECRET="change-me-to-a-long-random-secret"
JWT_EXPIRES_IN="12h"

# Initial admin account used by prisma seed.
SEED_ADMIN_USERNAME="admin"
SEED_ADMIN_PASSWORD="change-me-before-deploy"
SEED_ADMIN_DISPLAY_NAME="Admin"

# Container startup switches.
PORT="3000"
RUN_DB_PUSH="true"
RUN_DB_SEED="true"