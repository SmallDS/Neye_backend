# API 容器使用的 PostgreSQL 连接地址
DATABASE_URL=postgresql://neye:change-me@postgres:5432/neye?schema=public

# JWT 签名密钥，生产环境必须替换为强随机字符串
JWT_SECRET=change-me-to-a-long-random-secret
# 登录令牌有效期
JWT_EXPIRES_IN=12h

# 允许访问 API 的 Web 来源，多个地址使用逗号分隔
CORS_ORIGINS=https://web.example.com

# 初始化管理员账号，仅在 RUN_DB_SEED=true 时使用
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=change-me-before-deploy
SEED_ADMIN_DISPLAY_NAME=Admin

# API 容器内部监听端口
PORT=3000

# 数据库变更默认不随 API 进程启动；应由独立发布任务执行
RUN_DB_MIGRATIONS=false
RUN_DB_PUSH=false
# 仅在已审查 Prisma 警告并确认本次结构变更时临时开启，升级成功后改回 false
ALLOW_UNSAFE_DB_PUSH=false
RUN_DB_PUSH_ACCEPT_DATA_LOSS=false

# 是否执行初始化管理员种子，已有生产数据时保持 false
RUN_DB_SEED=false

# 是否自动回填历史账号租户关系
RUN_USER_TENANT_BACKFILL=false
# 是否自动回填客户姓名拼音查询字段
RUN_CUSTOMER_PINYIN_BACKFILL=false

# 微信 API 请求超时，允许 1000-30000 毫秒
WECHAT_API_TIMEOUT_MS=8000

# API 前有反向代理时填写可信代理跳数；直连保持 0
TRUST_PROXY_HOPS=0

# Large import pipeline (capacity-limited, non-streaming XLSX parsing; limits are not unlimited)
IMPORT_MAX_FILE_BYTES=52428800
IMPORT_MAX_ROWS=50000
IMPORT_MAX_COLUMNS=80
IMPORT_MAX_SHEETS=10
IMPORT_BATCH_SIZE=750
# This release intentionally clamps worker concurrency to 1 per API instance.
IMPORT_WORKER_CONCURRENCY=1